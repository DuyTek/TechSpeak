{
  "manifest_version": 3,
  "name": "TechSpeak",
  "version": "1.0.0",
  "description": "Instantly explains tech jargon — idempotent, blast radius, yak shaving — right where you're reading.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "TechSpeak",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
